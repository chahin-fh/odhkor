{
  "expo": {
    "name": "odhkor",
    "slug": "odhkor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logodhikr.png",
    "scheme": "test",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logodhikr.png",
        "backgroundImage": "./assets/images/logodhikr.png",
        "monochromeImage": "./assets/images/logodhikr.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.shyno2005.odhkor"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logodhikr.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logodhikr.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "27020cb9-0068-4514-bfb8-e8b0becc5d04"
      }
    }
  }
}
